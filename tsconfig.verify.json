{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "outDir": "./verification/dist",
    "noEmit": false
  },
  "include": [
    "src/store/**/*",
    "src/constants/**/*",
    "src/types/**/*",
    "verification/**/*"
  ]
}
