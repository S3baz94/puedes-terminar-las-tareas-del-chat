{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/((?!assets|api|favicon.ico|manifest.webmanifest|service-worker.js|offline.html|pwa-icon.svg).*)",
      "destination": "/index.html"
    }
  ]
}
